<section class="wb-overflow-hidden-x">
  <div class="wb-container">
    {% render 'wb-landing-hero-markup',
      video_file: section.settings.video_file,
      background_image: section.settings.background_image,
      title: section.settings.title,
      description: section.settings.description,
      primary_button_text: section.settings.primary_button_text,
      primary_button_url: section.settings.primary_button_url,
      secondary_button_text: section.settings.secondary_button_text,
      secondary_button_url: section.settings.secondary_button_url
    %}
  </div>
</section>

{% schema %}
{
  "name": "Landing Hero",
  "settings": [
    {
      "type": "text",
      "id": "video_file",
      "label": "Video filename",
      "info": "Optional. Upload video to assets folder and enter filename here. Leave empty to show static image instead."
    },
    {
      "type": "text",
      "id": "background_image",
      "label": "Background image filename",
      "default": "wb-whisky-bow.jpg",
      "info": "Fallback image shown while video loads, or main image if no video is set"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title text",
      "default": "Create something"
    },
    {
      "type": "inline_richtext",
      "id": "description",
      "label": "Description text",
      "default": "When you're looking for that bottle of whisky nobody else has."
    },
    {
      "type": "text",
      "id": "primary_button_text",
      "label": "Primary button text",
      "default": "Create something"
    },
    {
      "type": "url",
      "id": "primary_button_url",
      "label": "Primary button URL"
    },
    {
      "type": "text",
      "id": "secondary_button_text",
      "label": "Secondary button text",
      "default": "Get a voucher"
    },
    {
      "type": "url",
      "id": "secondary_button_url",
      "label": "Secondary button URL"
    }
  ],
  "presets": [
    {
      "name": "WB - Landing Hero"
    }
  ]
}
{% endschema %}
