{{ 'template-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

{%- unless section.settings.quick_add == 'none' -%}
  {{ 'quick-add.css' | asset_url | stylesheet_tag }}
{%- endunless -%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="wb-container">
  <div class="wb-padding">
    {%- assign excluded_collections_raw = section.settings.excluded_collection | split: ',' -%}
    {%- assign excluded_collections = '' -%}
    {%- for item in excluded_collections_raw -%}
      {%- assign trimmed = item | strip -%}
      {%- assign excluded_collections = excluded_collections | append: trimmed | append: ',' -%}
    {%- endfor -%}
    <div class="wb-buttons">
      {%- assign first_collection = true -%}
      {%- for collection in collections -%}
        {%- unless excluded_collections contains collection.title or collection.handle == 'all' -%}
          {%- assign filter_id = collection.title | handleize -%}
          <span class="wb-radio">
            <input
              type="radio"
              name="wb-filter"
              value="{{ collection.title }}"
              id="filter-{{ filter_id }}"
              data-collection="{{ collection.title }}"
              {%- if first_collection %}
                checked
              {%- endif -%}
            >
            <label for="filter-{{ filter_id }}">{{ collection.title }}</label>
          </span>
          {%- assign first_collection = false -%}
        {%- endunless -%}
      {%- endfor -%}
    </div>

    <ul
      class="wb-productsgrid wb-tightergrid grid grid--{{ section.settings.columns_mobile }}-col-tablet-down grid--{{ section.settings.columns_desktop }}-col-desktop"
      role="list"
    >
      {%- for product in collections.all.products limit: 250 -%}
        {%- assign has_allowed_collection = false -%}
        {%- for collection in product.collections -%}
          {%- unless excluded_collections contains collection.title -%}
            {%- assign has_allowed_collection = true -%}
            {%- break -%}
          {%- endunless -%}
        {%- endfor -%}

        {%- if has_allowed_collection -%}
          {%- assign product_collections = '' -%}
          {%- for collection in product.collections -%}
            {%- unless excluded_collections contains collection.title -%}
              {%- assign product_collections = product_collections | append: collection.title | append: ',' -%}
            {%- endunless -%}
          {%- endfor -%}

          <li class="wb-productcell grid__item product-item" data-collections="{{ product_collections }}">
            {% render 'card-product',
              card_product: product,
              media_aspect_ratio: section.settings.image_ratio,
              image_shape: section.settings.image_shape,
              show_secondary_image: section.settings.show_secondary_image,
              show_vendor: section.settings.show_vendor,
              show_rating: section.settings.show_rating,
              quick_add: section.settings.quick_add,
              section_id: section.id
            %}
          </li>
        {%- endif -%}
      {%- endfor -%}
    </ul>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const radioInputs = document.querySelectorAll('input[name="wb-filter"]');
    const products = document.querySelectorAll('.product-item');

    function filterProducts() {
      const checkedRadio = document.querySelector('input[name="wb-filter"]:checked');
      if (!checkedRadio) return;

      const filterCollection = checkedRadio.getAttribute('data-collection');

      products.forEach((product) => {
        const productCollections = product.getAttribute('data-collections');
        const collectionsArray = productCollections
          .split(',')
          .map((c) => c.trim())
          .filter((c) => c);

        if (collectionsArray.includes(filterCollection)) {
          product.style.display = '';
        } else {
          product.style.display = 'none';
        }
      });
    }

    radioInputs.forEach((radio) => {
      radio.addEventListener('change', filterProducts);
    });

    // Run filter on page load for the initially checked radio
    filterProducts();
  });
</script>

{% schema %}
{
  "name": "Shop All Products",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "excluded_collection",
      "label": "Excluded collection title",
      "default": "Anniversaries, Birthdays, Celebrations",
      "info": "Products in these collections will not be displayed. Separate multiple collection titles with commas."
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 4,
      "label": "Number of columns on desktop"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "options": [
        {
          "value": "1",
          "label": "1 column"
        },
        {
          "value": "2",
          "label": "2 columns"
        }
      ],
      "default": "2",
      "label": "Number of columns on mobile"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Product card"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "Adapt to image"
        },
        {
          "value": "portrait",
          "label": "Portrait"
        },
        {
          "value": "square",
          "label": "Square"
        }
      ],
      "default": "adapt",
      "label": "Image ratio"
    },
    {
      "type": "select",
      "id": "image_shape",
      "options": [
        {
          "value": "default",
          "label": "Default"
        },
        {
          "value": "arch",
          "label": "Arch"
        },
        {
          "value": "blob",
          "label": "Blob"
        },
        {
          "value": "chevronleft",
          "label": "Chevron left"
        },
        {
          "value": "chevronright",
          "label": "Chevron right"
        },
        {
          "value": "diamond",
          "label": "Diamond"
        },
        {
          "value": "parallelogram",
          "label": "Parallelogram"
        },
        {
          "value": "round",
          "label": "Round"
        }
      ],
      "default": "default",
      "label": "Image shape"
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "default": false,
      "label": "Show second image on hover"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": false,
      "label": "Show vendor"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "default": false,
      "label": "Show product rating"
    },
    {
      "type": "select",
      "id": "quick_add",
      "default": "none",
      "label": "Quick add button",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "standard",
          "label": "Standard"
        },
        {
          "value": "bulk",
          "label": "Bulk"
        }
      ]
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Shop All Products"
    }
  ]
}
{% endschema %}
