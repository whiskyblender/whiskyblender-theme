{{ 'glide.core.css' | asset_url | stylesheet_tag }}
{{ 'glide.custom.css' | asset_url | stylesheet_tag }}
{{ 'wb-collaborate.css' | asset_url | stylesheet_tag }}

<section>
  <div class="wb-container">
    <div class="wb-padding wb-collection-copy">
      <p>We work with individuals, brands, and businesses to craft bespoke bottles of Scotch whisky that tell a story &mdash; so <a href="#wb-getintouch">tell us yours</a>.</p>
      <p>Whether you're launching a limited-edition release, celebrating a milestone, or building something entirely new, our team helps you create a Scotch that carries your name, your values, and your taste.</p>
      <p>From cask selection and blending to design, bottling, and packaging, we'll guide you through each step of the journey. The result? A whisky that's uniquely yours — authentic, memorable, and made to share.</p>
    </div>

    <div class="glide wb-collabs">
      <div class="glide__track" data-glide-el="track">
        <ul class="glide__slides wb-collabphotos">
          <li class="glide__slide wb-collabphoto"><img src="{{ '01_hoonjuice.jpg' | asset_url }}" alt="Hoon Juice collaboration" loading="lazy"></li>
          <li class="glide__slide wb-collabphoto"><img src="{{ '02_glasgow850.jpg' | asset_url }}" alt="Glasgow 850 collaboration" loading="lazy"></li>
          <li class="glide__slide wb-collabphoto"><img src="{{ '03_goldendrop.jpg' | asset_url }}" alt="Golden Drop collaboration" loading="lazy"></li>
          <li class="glide__slide wb-collabphoto"><img src="{{ '04_joeydunlop.jpg' | asset_url }}" alt="Joey Dunlop collaboration" loading="lazy"></li>
          <li class="glide__slide wb-collabphoto"><img src="{{ '05_caskslug.jpg' | asset_url }}" alt="Cask Slug collaboration" loading="lazy"></li>
          <li class="glide__slide wb-collabphoto"><img src="{{ '06_alba.jpg' | asset_url }}" alt="Alba collaboration" loading="lazy"></li>
          <li class="glide__slide wb-collabphoto"><img src="{{ '07_oldsport.jpg' | asset_url }}" alt="Old Sport collaboration" loading="lazy"></li>
          <li class="glide__slide wb-collabphoto"><img src="{{ '08_joker.jpg' | asset_url }}" alt="Joker collaboration" loading="lazy"></li>
          <li class="glide__slide wb-collabphoto"><img src="{{ '09_dramsylvania.jpg' | asset_url }}" alt="Dramsylvania collaboration" loading="lazy"></li>
        </ul>
      </div>
    </div>
  </div>
</section>

<section class="wb-banded">
  <div class="wb-container">
    <div class="wb-padding">
      <a id="wb-getintouch"></a>
      {% render 'wb-contact-form-markup',
        heading: "Let's talk Scotch",
        description: "Tell us about an idea, a label, or even just a spark of inspiration."
      %}
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    new Glide('.wb-collabs', {
      type: 'carousel',
      gap: 40,
      perView: 4,
      autoplay: 1,
      animationDuration: 5000,
      animationTimingFunc: 'linear',
      hoverpause: true,
      breakpoints: {
        600: { perView: 2, animationDuration: 3000, gap: 20 },
        768: { perView: 3, animationDuration: 4000, gap: 30 }
      }
    }).mount();
  });
</script>

<script src="{{ 'glide.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "WB Collaborate",
  "settings": []
}
{% endschema %}
